// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum pour les rôles utilisateur
enum UserRole {
  USER
  STARTUP
  ADMIN
}

// Enum pour les types de transactions
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  DIVIDEND
  FEE
  REFUND
}

// Enum pour les statuts de transaction
enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// Enum pour les statuts d'investissement
enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// Modèle User principal
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  phoneNumber       String?   @map("phone_number")
  kycStatus      String   @default("PENDING") 
  role              UserRole
  isActive          Boolean   @default(true)
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret")
  lastLogin         DateTime? @map("last_login")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  // Relations
  wallet         Wallet?
  investments    Investment[]
  transactions   Transaction[]
  loginAttempts  LoginAttempt[]
  profile        UserProfile?
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  
  @@map("users")
}

// Profil utilisateur
model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  avatarUrl       String?  @map("avatar_url")
  location        String?
  dateOfBirth     DateTime? @map("date_of_birth")
  investorType    String?  @map("investor_type")
  riskProfile     String?  @map("risk_profile")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("user_profiles")
}

// Tentatives de connexion
model LoginAttempt {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  ipAddress   String   @map("ip_address")
  userAgent   String?  @map("user_agent")
  successful  Boolean
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@map("login_attempts")
}

// Tokens de rafraîchissement
model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// Portefeuille
model Wallet {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal   @default(0) @db.Decimal(20, 2)
  lockedBalance Decimal   @default(0) @map("locked_balance") @db.Decimal(20, 2)
  currency      String    @default("XAF")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  transactions  Transaction[]
  
  @@map("wallets")
}

// Transactions
model Transaction {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId    String              @map("wallet_id")
  wallet      Wallet              @relation(fields: [walletId], references: [id])
  type        TransactionType
  status      TransactionStatus   @default(PENDING)
  amount      Decimal             @db.Decimal(20, 2)
  fee         Decimal             @default(0) @db.Decimal(20, 2)
  description String?
  reference   String              @unique
  metadata    Json?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([walletId])
  @@index([type])
  @@index([status])
  @@map("transactions")
}

// Investissements
model Investment {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  startupId       String            @map("startup_id")
  startup         Startup           @relation(fields: [startupId], references: [id])
  amount          Decimal           @db.Decimal(20, 2)
  shares          Int               @default(0)
  status          InvestmentStatus  @default(ACTIVE)
  investedAt      DateTime          @default(now()) @map("invested_at")
  maturityDate    DateTime?         @map("maturity_date")
  returnAmount    Decimal?          @map("return_amount") @db.Decimal(20, 2)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([startupId])
  @@index([status])
  @@map("investments")
}

// Startups
model Startup {
  id              String    @id @default(uuid())
  name            String
  description     String
  logo            String?
  website         String?
  pitch           String?
  valuationTarget Decimal   @map("valuation_target") @db.Decimal(20, 2)
  raisedAmount    Decimal   @default(0) @map("raised_amount") @db.Decimal(20, 2)
  minInvestment   Decimal   @map("min_investment") @db.Decimal(20, 2)
  maxInvestment   Decimal   @map("max_investment") @db.Decimal(20, 2)
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  investments     Investment[]
  
  @@map("startups")
}

// Notifications
model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}