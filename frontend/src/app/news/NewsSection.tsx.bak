import React, { useState, useEffect } from 'react';
import { TrendingUp, Calendar, Globe, AlertCircle, Zap, Clock } from 'lucide-react';

// Hook personnalisé pour l'effet typewriter
const useTypewriter = (text: string, speed: number = 50, delay: number = 0, startTyping: boolean = true) => {
  const [displayedText, setDisplayedText] = useState('');
  const [isComplete, setIsComplete] = useState(false);

  useEffect(() => {
    if (!startTyping) {
      setDisplayedText('');
      setIsComplete(false);
      return;
    }

    setDisplayedText('');
    setIsComplete(false);
    
    const timeout = setTimeout(() => {
      let currentIndex = 0;
      
      const interval = setInterval(() => {
        if (currentIndex <= text.length) {
          setDisplayedText(text.slice(0, currentIndex));
          currentIndex++;
        } else {
          setIsComplete(true);
          clearInterval(interval);
        }
      }, speed);

      return () => clearInterval(interval);
    }, delay);

    return () => clearTimeout(timeout);
  }, [text, speed, delay, startTyping]);

  return { displayedText, isComplete };
};

// Composant pour le texte avec effet typewriter
const TypewriterText = ({ text, speed = 30, delay = 0, className = '', startTyping = true }: {
  text: string;
  speed?: number;
  delay?: number;
  className?: string;
  startTyping?: boolean;
}) => {
  const { displayedText, isComplete } = useTypewriter(text, speed, delay, startTyping);
  
  return (
    <span className={className}>
      {displayedText}
      {!isComplete && startTyping && <span className="animate-pulse text-orange-400">|</span>}
    </span>
  );
};

const NewsSection = () => {
  const [isVisible, setIsVisible] = useState(false);
  const [hoveredCard, setHoveredCard] = useState<number | null>(null);

  useEffect(() => {
    setIsVisible(true);
  }, []);

  const newsArticles = [
    {
      id: 1,
      title: "L'écosystème des startups africaines attire un investissement record de 5,2 milliards de dollars",
      summary: "Les startups fintech dominent avec 65% des financements, suivies par l'agritech et la santé numérique.",
      date: "Il y a 2 jours",
      category: "Financement",
      image: "https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=800&h=400&fit=crop",
      readTime: "3 min",
      isUrgent: true,
      badge: "DERNIÈRE MINUTE"
    },
    {
      id: 2,
      title: "M-Pesa révolutionne les paiements transfrontaliers en Afrique de l'Est",
      summary: "La plateforme mobile money s'étend à 7 nouveaux pays, facilitant le commerce régional.",
      date: "Il y a 5 jours",
      category: "Innovation",
      image: "https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=800&h=400&fit=crop",
      readTime: "5 min",
      isHot: true,
      badge: "TENDANCE"
    },
    {
      id: 3,
      title: "Le Nigeria lance un fonds de 600 millions pour soutenir les startups tech",
      summary: "Initiative gouvernementale visant à créer 1 million d'emplois dans le secteur technologique d'ici 2025.",
      date: "Il y a 1 semaine",
      category: "Politique",
      image: "https://images.unsplash.com/photo-1553484771-371a605b060b?w=800&h=400&fit=crop",
      readTime: "4 min",
      badge: "EXCLUSIF"
    }
  ];

  const getCategoryColor = (category: string) => {
    switch (category) {
      case 'Financement':
        return 'from-emerald-500 to-teal-500';
      case 'Innovation':
        return 'from-orange-500 to-amber-500';
      case 'Politique':
        return 'from-blue-500 to-indigo-500';
      default:
        return 'from-gray-500 to-gray-600';
    }
  };

  const getBadgeStyle = (badge: string) => {
    switch (badge) {
      case 'DERNIÈRE MINUTE':
        return 'bg-red-500 text-white animate-pulse';
      case 'TENDANCE':
        return 'bg-gradient-to-r from-orange-500 to-amber-500 text-white';
      case 'EXCLUSIF':
        return 'bg-purple-600 text-white';
      default:
        return 'bg-gray-600 text-white';
    }
  };

  return (
    <section className="py-12 relative">
      {/* Bandeau Breaking News */}
      <div className="absolute -top-6 left-0 right-0 z-10">
        <div className="mx-auto max-w-fit">
          <div className="flex items-center gap-2 px-4 py-2 bg-red-500/90 backdrop-blur-xl rounded-full shadow-lg animate-bounce">
            <AlertCircle className="w-4 h-4 text-white animate-pulse" />
            <span className="text-sm font-bold text-white uppercase tracking-wider">Breaking News</span>
            <div className="w-2 h-2 bg-white rounded-full animate-pulse" />
          </div>
        </div>
      </div>

      <div className="mb-8 mt-8">
        <div className="flex items-center justify-between mb-6">
          <div>
            <div className="flex items-center gap-3 mb-2">
              <h2 className="text-3xl font-bold text-white">
                Actualités du marché
              </h2>
              <div className="flex items-center gap-1 px-3 py-1 bg-orange-500/20 rounded-full">
                <Zap className="w-4 h-4 text-orange-400 animate-pulse" />
                <span className="text-xs font-semibold text-orange-400">LIVE</span>
              </div>
            </div>
            <p className="text-white/60 flex items-center gap-2">
              <Clock className="w-4 h-4" />
              Restez informé des dernières tendances et opportunités
            </p>
          </div>
          <button className="px-6 py-2 bg-white/10 hover:bg-white/20 text-white rounded-xl font-medium transition-all duration-300 backdrop-blur border border-white/20 hover:border-orange-400/50 group">
            <span className="group-hover:text-orange-400 transition-colors">Voir tout</span>
          </button>
        </div>
      </div>

      <div className="grid md:grid-cols-3 gap-6">
        {newsArticles.map((article, index) => (
          <article 
            key={article.id}
            className={`group relative backdrop-blur-xl rounded-2xl border border-white/20 overflow-hidden hover:transform hover:scale-[1.02] transition-all duration-300 ${
              isVisible ? 'animate-fade-in-up' : 'opacity-0'
            }`}
            style={{
              background: 'linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%)',
              boxShadow: '0 8px 32px 0 rgba(31, 38, 135, 0.37)',
              animationDelay: `${0.3 + index * 0.2}s`
            }}
            onMouseEnter={() => setHoveredCard(article.id)}
            onMouseLeave={() => setHoveredCard(null)}
          >
            {/* Badge urgent/tendance */}
            {article.badge && (
              <div className="absolute top-4 right-4 z-20">
                <span className={`px-3 py-1 rounded-full text-xs font-bold ${getBadgeStyle(article.badge)} shadow-lg`}>
                  {article.badge}
                </span>
              </div>
            )}

            {/* Image avec overlay gradient */}
            <div className="relative h-48 overflow-hidden">
              <img
                src={article.image}
                alt={article.title}
                className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
              
              {/* Catégorie badge */}
              <div className="absolute top-4 left-4">
                <span className={`px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${getCategoryColor(article.category)}`}>
                  {article.category}
                </span>
              </div>

              {/* Indicateur Live pour les articles urgents */}
              {article.isUrgent && (
                <div className="absolute bottom-4 right-4 flex items-center gap-2 px-3 py-1 bg-red-500/80 backdrop-blur rounded-full">
                  <div className="w-2 h-2 bg-white rounded-full animate-pulse" />
                  <span className="text-xs font-semibold text-white">EN DIRECT</span>
                </div>
              )}
            </div>

            {/* Contenu */}
            <div className="p-6">
              <h3 className="text-xl font-semibold text-white mb-2 group-hover:text-orange-400 transition-colors duration-300 line-clamp-2 min-h-[3.5rem]">
                {isVisible && (
                  <TypewriterText 
                    text={article.title} 
                    speed={20} 
                    delay={800 + index * 300}
                    startTyping={hoveredCard === article.id || isVisible}
                  />
                )}
              </h3>
              <p className="text-white/60 text-sm mb-4 line-clamp-2 min-h-[2.5rem]">
                {isVisible && hoveredCard === article.id && (
                  <TypewriterText 
                    text={article.summary} 
                    speed={15} 
                    delay={0}
                    startTyping={true}
                  />
                )}
                {!hoveredCard && isVisible && article.summary}
              </p>
              
              {/* Métadonnées */}
              <div className="flex items-center justify-between text-xs text-white/40">
                <div className="flex items-center gap-4">
                  <span className="flex items-center gap-1">
                    <Calendar className="w-3 h-3" />
                    {article.date}
                  </span>
                  <span className="flex items-center gap-1">
                    <Globe className="w-3 h-3" />
                    {article.readTime}
                  </span>
                </div>
                <div className="opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center gap-1">
                  <span className="text-orange-400 text-sm font-semibold">Lire</span>
                  <TrendingUp className="w-4 h-4 text-orange-400" />
                </div>
              </div>
            </div>

            {/* Effet de bordure animée pour les articles urgents */}
            {article.isUrgent && (
              <div className="absolute inset-0 pointer-events-none">
                <div className="absolute inset-0 opacity-50">
                  <div className="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-500 to-transparent animate-slide-right" />
                  <div className="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-500 to-transparent animate-slide-left" />
                </div>
              </div>
            )}
          </article>
        ))}
      </div>

      {/* Ticker d'informations rapides */}
      <div className="mt-8 relative overflow-hidden rounded-xl bg-gradient-to-r from-orange-500/10 to-amber-500/10 backdrop-blur-xl border border-orange-500/20 p-4">
        <div className="flex items-center gap-4">
          <div className="flex items-center gap-2 flex-shrink-0">
            <AlertCircle className="w-5 h-5 text-orange-400 animate-pulse" />
            <span className="font-bold text-orange-400 uppercase text-sm">Flash Info</span>
          </div>
          <div className="relative flex-1 overflow-hidden">
            <div className="animate-marquee whitespace-nowrap">
              <span className="text-white/80 text-sm">
                📈 Le marché africain de la fintech devrait atteindre 65 milliards $ d'ici 2030 • 
                🚀 Flutterwave devient la 4ème licorne africaine • 
                💰 L'Égypte attire 40% des investissements tech du continent • 
                🌍 Plus de 700 startups actives dans 54 pays africains
              </span>
            </div>
          </div>
        </div>
      </div>

      <style jsx>{`
        @keyframes fade-in-up {
          from {
            opacity: 0;
            transform: translateY(20px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        @keyframes slide-right {
          from {
            transform: translateX(-100%);
          }
          to {
            transform: translateX(100%);
          }
        }

        @keyframes slide-left {
          from {
            transform: translateX(100%);
          }
          to {
            transform: translateX(-100%);
          }
        }

        @keyframes marquee {
          0% {
            transform: translateX(100%);
          }
          100% {
            transform: translateX(-100%);
          }
        }

        .animate-fade-in-up {
          animation: fade-in-up 0.6s ease-out forwards;
        }

        .animate-slide-right {
          animation: slide-right 3s linear infinite;
        }

        .animate-slide-left {
          animation: slide-left 3s linear infinite;
        }

        .animate-marquee {
          animation: marquee 30s linear infinite;
        }
      `}</style>
    </section>
  );
};

export default NewsSection;